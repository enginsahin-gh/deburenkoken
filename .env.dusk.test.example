# Dusk Test Environment - voor tests tegen https://test.deburenkoken.nl
#
# GEBRUIK:
#   1. Kopieer dit bestand naar .env.dusk.test
#   2. Vul de HTTP Basic Auth credentials in
#   3. Draai tests met: php artisan dusk --env=test
#
# BELANGRIJK: .env.dusk.test bevat credentials en mag NOOIT gecommit worden!

APP_NAME="DeBurenKoken"
APP_ENV=test
APP_KEY=base64:JgxlWMkvFNz5d4PqgJjqzVOBMHUahcliRgHvgYei/Sw=
APP_DEBUG=false
APP_URL=https://test.deburenkoken.nl

# HTTP Basic Auth voor de test omgeving (verplicht!)
DUSK_HTTP_USERNAME=
DUSK_HTTP_PASSWORD=

# GEEN database connectie voor remote tests
# De tests draaien tegen bestaande test data op de server
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# Skip database truncation - gebruik dit voor externe test servers
# waar je geen directe database toegang hebt
DUSK_SKIP_TRUNCATION=true

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# BELANGRIJK: Mail moet uitgeschakeld zijn voor tests!
# MailChannels (Hostinger) blokkeert e-mails naar Gmail+ adressen met error 5.7.1
# Dit voorkomt bounce-back mails naar Noreply@deburenkoken.nl
MAIL_MAILER=array
