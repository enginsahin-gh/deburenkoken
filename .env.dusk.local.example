APP_NAME=DeBurenKoken
APP_ENV=dusk.testing
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
# Voor lokale tests en GitHub Actions - gebruik http://127.0.0.1:8000
# Voor remote tests tegen test.deburenkoken.nl, gebruik .env.dusk.test.example
APP_URL=http://127.0.0.1:8000
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Test environment HTTP Basic Auth credentials
# Alleen nodig voor remote tests tegen test.deburenkoken.nl
# Laat leeg voor lokale tests
DUSK_HTTP_USERNAME=
DUSK_HTTP_PASSWORD=

DUSK_DRIVER_URL=http://localhost:9515

# Database configuration for test environment
# Niet nodig voor externe tests, maar vereist door Laravel
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=testing
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_CONNECTION=log
CACHE_STORE=array
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# BELANGRIJK: Gebruik altijd 'array' voor tests!
# MailChannels (Hostinger) blokkeert e-mails naar Gmail+ adressen met error 5.7.1
# Dit voorkomt bounce-back mails naar Noreply@deburenkoken.nl
MAIL_MAILER=array
